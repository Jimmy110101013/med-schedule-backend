# Binary & large data files — avoid polluting context
data/*.pdf
data/*.db
data/*.sqlite
data/*.sqlite3

# Dependencies
node_modules/
frontend/node_modules/

# Python virtualenv
venv/
.venv/

# Next.js build output
frontend/.next/
frontend/out/

# Python cache
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd

# Logs
*.log
logs/

# OS & editor noise
.DS_Store
Thumbs.db
*.swp
*.swo

# Environment files (secrets)
.env
frontend/.env.local

# Git internals
.git/
